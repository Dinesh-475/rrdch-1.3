## SECTION 2: API KEYS NEEDED
## ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
## ⚠️  ASK THE USER FOR THESE BEFORE STARTING — DO NOT HARDCODE

API_KEYS_REQUIRED:
  - ANTHROPIC_API_KEY        # For AI Symptom Checker (Claude claude-sonnet-4-20250514)
                             # Get at: https://console.anthropic.com
  - JWT_SECRET               # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
  - EMAIL_USER               # Gmail address for appointment confirmations
  - EMAIL_PASS               # Gmail App Password (not regular password)
  - GOOGLE_MAPS_API_KEY      # Optional — basic embed works without key

## INSTRUCTION TO AI ASSISTANT:
## Before generating any code that calls the Anthropic API or uses JWT,
## STOP and ask the user:
## "Please provide your ANTHROPIC_API_KEY and JWT_SECRET before I generate
## the files that need them. I will not hardcode placeholder values."

